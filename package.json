{
  "name": "n-able-n-sight-api",
  "version": "2.0.0",
  "description": "Full-coverage TypeScript client for the N-able N-sight RMM Data Extraction API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "n-able",
    "n-sight",
    "rmm",
    "api",
    "monitoring",
    "managed-antivirus",
    "backup",
    "asset-tracking"
  ],
  "author": "ExactDoug",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ExactDoug/n-able-n-sight-api.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
